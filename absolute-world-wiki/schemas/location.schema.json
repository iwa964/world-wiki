{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://absolute-world-wiki.local/schemas/location.schema.json",
  "title": "Location",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "summary", "type", "notable_features", "known_by"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string" },
    "summary": { "type": "string" },
    "type": { "type": "string", "enum": ["district", "settlement", "ruin", "landmark", "region"] },
    "parent_location": { "type": "string" },
    "notable_features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "resident_factions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "known_by": {
      "type": "array",
      "items": { "type": "string" }
    },
    "secrets": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "notes": { "type": "string" }
  }
}
