{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://absolute-world-wiki.local/schemas/occupation.schema.json",
  "title": "Occupation",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "summary", "social_role", "common_skills", "typical_tools"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string" },
    "summary": { "type": "string" },
    "social_role": { "type": "string" },
    "common_skills": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "typical_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "associated_factions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "known_locations": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "notes": { "type": "string" }
  }
}
